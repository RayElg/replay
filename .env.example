# Replay environment template.
#
# `make dev` works with these defaults — copy this file to .env and you're done.
# To deploy with TLS / a real host, also uncomment the
# "═══ Production overrides ═══" block at the bottom and fill in the marked
# values, then bring the stack up with the prod overlay:
#
#   docker compose -f docker-compose.yml -f deploy/docker-compose.prod.yml up -d
#
# Generate secret values with:  openssl rand -hex 32

# ──────────────────────────────────────────────────────────────────────────
# Core services
# ──────────────────────────────────────────────────────────────────────────

# PostgreSQL (pgmqtt)
POSTGRES_USER=replay
POSTGRES_PASSWORD=replay
POSTGRES_DB=postgres

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=replay-artifacts

# ──────────────────────────────────────────────────────────────────────────
# Control plane
# ──────────────────────────────────────────────────────────────────────────

DATABASE_URL=postgres://replay:replay@pgmqtt:5432/postgres?sslmode=disable
LISTEN_ADDR=:8080

# Public URL the browser uses to fetch artifacts (presigned GETs). Must point
# at the host the *browser* can reach — for TLS deployments override this in
# the Production block below.
PUBLIC_OBJECT_STORE=http://localhost:9000/replay-artifacts

# Internal URL the control-plane uses to *read* artifacts when composing agent
# vision context. Stays plaintext HTTP on the docker network.
INTERNAL_OBJECT_STORE=http://minio:9000/replay-artifacts

# Canonical external URL the browser sees (https://replay.acme.com). Used for
# any link the control-plane generates for the UI (invite / reset links).
# If unset, derived from the request (X-Forwarded-Proto + X-Forwarded-Host).
REPLAY_EXTERNAL_URL=

# Set to "true" when the control-plane is served behind HTTPS so session
# cookies get the Secure flag. Also enables a boot-time check that refuses
# to start without the secret bundle below set — flipping this to true is
# the operator's signal of "this is a real deployment".
REPLAY_COOKIE_SECURE=false

# Days to retain audit_events rows (default 90).
REPLAY_AUDIT_RETENTION_DAYS=90

# Browser session lifetime in days (default 30; max 365). Tighter than 30 is
# common for enterprise compliance; looser for low-friction internal tools.
REPLAY_SESSION_LIFETIME_DAYS=30

# Optional: enable the agent's local-file-read tools by listing absolute
# repo roots the agent may read (colon-separated).
REPLAY_ALLOWED_REPO_PATHS=

# ──────────────────────────────────────────────────────────────────────────
# Agent (Anthropic Claude)
# ──────────────────────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=
AGENT_MODEL=claude-sonnet-4-6

# When background auto-triage classifies a failure as a real_failure or test_bug
# at medium+ confidence and the run is tied to an open GitHub PR, the agent posts
# its findings as a PR comment (upserted — one per run, updated on rerun). Set to
# "false" to disable autonomous PR comments; the agent can still comment in
# interactive chat when asked. Default: true.
REPLAY_AUTO_PR_COMMENTS=true

# ──────────────────────────────────────────────────────────────────────────
# Secrets (split — one per purpose)
# ──────────────────────────────────────────────────────────────────────────
#
# Dev can run with these empty; the fail-loud check kicks in only when
# REPLAY_COOKIE_SECURE=true (i.e. you're deploying for real).

# AES-256-GCM master key for integration token encryption at rest.
REPLAY_ENCRYPT_KEY=

# Retired encryption keys kept readable during rotation (comma- or whitespace-
# separated). Set REPLAY_ENCRYPT_KEY to the new key, list the old one(s) here, then
# run `control-plane rewrap-secrets`. See README → "Rotating REPLAY_ENCRYPT_KEY".
REPLAY_ENCRYPT_KEY_PREVIOUS=

# Bearer token for CI webhook auth (POST /api/webhooks/run). A single-tenant
# convenience; per-project tokens (managed in the UI) are preferred otherwise.
REPLAY_WEBHOOK_TOKEN=

# Fallback HMAC secret for verifying GitHub push webhooks (POST /api/webhooks/github),
# used to auto-sync repo-linked scripts when files change upstream. Per-integration
# secrets (set in the UI when connecting a repo) take precedence; this global value
# is a single-tenant convenience. Leave blank to require a per-integration secret.
REPLAY_GITHUB_WEBHOOK_SECRET=

# HS256 secret for the browser-issued broker JWT (only consulted when
# REPLAY_MQTT_TRUSTED_BROKER=true).
REPLAY_BROKER_JWT_SECRET=

# ──────────────────────────────────────────────────────────────────────────
# First-run admin
# ──────────────────────────────────────────────────────────────────────────
#
# Auth is password-based. On first boot, /setup mints the first admin user;
# API keys (rplx_…) work in every case for non-browser callers.

# First-run bootstrap: if the users table is empty on boot and these are set,
# a user is created automatically in the default workspace. Idempotent — once
# any user exists these vars are ignored.
REPLAY_BOOTSTRAP_USER_EMAIL=
REPLAY_BOOTSTRAP_USER_PASSWORD=

# First-run bootstrap: API key seeded into the api_keys table if it is empty.
# Mint one beforehand with `control-plane bootstrap-key`.
REPLAY_BOOTSTRAP_API_KEY=

# ──────────────────────────────────────────────────────────────────────────
# pgmqtt broker auth
# ──────────────────────────────────────────────────────────────────────────
#
# IMPORTANT — multi-tenant warning: community pgmqtt has no broker-side topic
# ACLs. SCRAM authenticates *who* can CONNECT, but every authenticated client
# can SUBSCRIBE to any topic, including other workspaces' run streams. The
# default deployment is single-tenant safe (everyone with a login is on the
# same workspace). For real multi-tenancy, run pgmqtt Enterprise with jwt/acl
# (set REPLAY_MQTT_TRUSTED_BROKER=true and see the Enterprise overrides block
# at the bottom of this file).
# See README → "Multi-tenant deployments" for the full picture.

# Password for the global `replay_runner` LOGIN role — control-plane provisions
# it via ALTER SYSTEM on startup; runner uses the same value in CONNECT.
REPLAY_RUNNER_MQTT_PASSWORD=replay-runner-dev

# "true" if your broker terminates JWTs (pgmqtt Enterprise with jwt/acl).
# Default: false — browser uses SCRAM-SHA-256 directly.
REPLAY_MQTT_TRUSTED_BROKER=false

# Set "false" to skip the boot-time pgmqtt ALTER SYSTEM autoconfig (useful for
# environments where the control-plane DB role isn't a superuser).
REPLAY_PGMQTT_AUTOCONFIG=true

# ──────────────────────────────────────────────────────────────────────────
# Runner
# ──────────────────────────────────────────────────────────────────────────

RUNNER_MQTT_BROKER_URL=tcp://pgmqtt:1883
RUNNER_DATABASE_URL=postgres://replay:replay@pgmqtt:5432/postgres?sslmode=disable
RUNNER_OBJECT_STORE=http://minio:9000/replay-artifacts
# Max Playwright runs per worker. Each Playwright process can use 500MB+
# so leave headroom on small machines.
RUNNER_CONCURRENCY=2

# ══════════════════════════════════════════════════════════════════════════
# Production overrides
# ══════════════════════════════════════════════════════════════════════════
#
# Uncomment and fill in to deploy with deploy/docker-compose.prod.yml.
# Everything below either replaces a value from above or is prod-only.
#
# Generate every CHANGE-ME with:  openssl rand -hex 32

# --- Public hostname ---
# Replay does not terminate TLS — put your own reverse proxy / LB in front (it
# serves REPLAY_DOMAIN and a separate artifacts host; see the deploy docs).
# REPLAY_DOMAIN is used to build the browser's wss://{domain}/mqtt URL.
# REPLAY_DOMAIN=replay.example.com

# --- Replace values from the dev block above ---
# REPLAY_EXTERNAL_URL=https://replay.example.com
# REPLAY_COOKIE_SECURE=true
# PUBLIC_OBJECT_STORE=https://artifacts.example.com/replay-artifacts
# POSTGRES_PASSWORD=CHANGE-ME
# MINIO_ROOT_USER=replay
# MINIO_ROOT_PASSWORD=CHANGE-ME
# DATABASE_URL=postgres://replay:CHANGE-ME@pgmqtt:5432/postgres?sslmode=disable
# RUNNER_DATABASE_URL=postgres://replay:CHANGE-ME@pgmqtt:5432/postgres?sslmode=disable

# --- Real secrets ---
# REPLAY_ENCRYPT_KEY=CHANGE-ME
# REPLAY_WEBHOOK_TOKEN=CHANGE-ME
# REPLAY_BROKER_JWT_SECRET=CHANGE-ME
# REPLAY_RUNNER_MQTT_PASSWORD=CHANGE-ME

# --- First admin (optional — skip and use /setup interactively instead) ---
# REPLAY_BOOTSTRAP_USER_EMAIL=admin@example.com
# REPLAY_BOOTSTRAP_USER_PASSWORD=CHANGE-ME

# ══════════════════════════════════════════════════════════════════════════
# Enterprise overrides (pgmqtt Enterprise license required)
# ══════════════════════════════════════════════════════════════════════════
#
# Uncomment alongside the Production block to switch browser→broker auth from
# SCRAM (validated against pg_authid) to short-lived Ed25519 JWTs validated by
# pgmqtt natively with topic-level ACLs. Your reverse proxy still fronts
# UI/API/artifacts; pgmqtt terminates its own native WSS on :9002:
#
#   docker compose -f docker-compose.yml \
#     -f deploy/docker-compose.prod.yml \
#     -f deploy/docker-compose.enterprise.yml \
#     up -d
#
# Drop a cert.crt + cert.key for REPLAY_DOMAIN into deploy/certs/ first —
# pgmqtt reads them from /certs to bind its WSS listener.

# REPLAY_MQTT_TRUSTED_BROKER=true
# REPLAY_BROKER_JWT_PRIVATE_KEY=CHANGE-ME-from-`control-plane gen-broker-jwt-key`
# REPLAY_PGMQTT_LICENSE_KEY=CHANGE-ME-from-pgmqtt-Enterprise-license
# NEXT_PUBLIC_MQTT_WS_URL=wss://replay.example.com:9002/mqtt
